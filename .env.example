TIKTOK_USERNAME=your_tiktok_username_here
PORT=3000

# Required for one-command APK build. Set to your live app URL (no trailing slash).
# Example: https://your-app.railway.app or https://tarot.yourdomain.com
DEPLOYED_URL=

# When the app UI is hosted on GitHub Pages (or another origin), list allowed origins here (comma-separated, no spaces).
# Example: CORS_ORIGINS=https://youruser.github.io
# CORS_ORIGINS=

# Capabilities tab: OAuth client IDs (create apps in Google Cloud Console / TikTok for Developers)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# TIKTOK_CLIENT_KEY=your-tiktok-client-key

# Mordechaius Maximus — AI chat (OpenAI)
# OPENAI_API_KEY=sk-your-openai-api-key
